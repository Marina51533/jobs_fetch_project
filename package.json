{
  "name": "jobs-fetch-project",
  "version": "1.0.0",
  "description": "Automatic job aggregation and publishing for DEV Career Community | Europe",
  "main": "src/pipeline/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/pipeline/index.js",
    "start:web3": "SOURCE_MODE=web3 node src/pipeline/index.js",
    "db:cleanup": "node src/cleanup.js",
    "schedule:macos": "zsh scripts/install-macos-launch-agent.sh",
    "schedule:macos:remove": "zsh scripts/uninstall-macos-launch-agent.sh",
    "test": "node --test src/**/*.test.js",
    "classify": "python3 classifier/classify.py",
    "sample:job": "node scripts/find-sample-job.js",
    "preview:ad": "python3 -m http.server 4173"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "dotenv": "^16.6.1",
    "node-fetch": "^3.3.2",
    "html-to-text": "^9.0.5"
  },
  "devDependencies": {},
  "keywords": ["jobs", "aggregation", "telegram", "greenhouse", "qa", "developer"],
  "license": "PRIVATE"
}
