# Database (SQLite file path — defaults to ./data/jobs.db)
DATABASE_PATH=./data/jobs.db

# Telegram — QA Bot
QA_BOT_TOKEN=123456:ABC-DEF...
QA_TOPIC_ID=1

# Telegram — Developer Bot
DEV_BOT_TOKEN=123456:ABC-DEF...
DEV_TOPIC_ID=2

# Telegram — Shared
TELEGRAM_CHAT_ID=-1001234567890

# Telegram — Admin
# User ID of the person allowed to approve/reject review items
ADMIN_CHAT_ID=123456789

# Optional: group/chat where review messages are sent.
# If omitted, review messages go directly to ADMIN_CHAT_ID.
REVIEW_CHAT_ID=-1001234567890

# Pipeline
FETCH_DELAY_MS=200
PUBLISH_DELAY_MS=1000
CONFIDENCE_THRESHOLD=0.8

# Optional: only process jobs updated in the last N days. Set 0 to disable.
MAX_SOURCE_JOB_AGE_DAYS=1
